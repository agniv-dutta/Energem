# Groq LLM (using Llama model via Groq)
GROQ_API_KEY=gsk_xxxxx
GROQ_MODEL=llama3-70b-8192

# Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# NewsAPI
NEWSAPI_KEY=xxxxx
NEWS_FETCH_INTERVAL_MINUTES=60

# Database
DATABASE_URL=sqlite:///./energem.db

# Risk scoring
CORRIDOR_WEIGHTS={"hormuz":1.5,"red_sea":1.2,"malacca":0.8,"suez":1.0,"land_route":0.9}

# API Config
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development

# LLM Config
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
