# Groq LLM (using Llama model via Groq)
GROQ_API_KEY=gsk_xxxxx
GROQ_MODEL=llama3-70b-8192

# NewsAPI
NEWSAPI_KEY=xxxxx

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/energem
REDIS_URL=redis://localhost:6379

# API Config
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development

# LLM Config
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
